# JalJeevan Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Optional: OpenAI for LLM-based legal RAG ──────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Pathway settings ──────────────────────────────────────────────────────────
# Set to 1 when running in WSL or Linux to use native Pathway engine
PATHWAY_REAL=0

# ── API Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Data Paths (optional overrides) ──────────────────────────────────────────
DOLPHIN_CSV_PATH=data/live_dolphin.csv
MINING_CSV_PATH=data/live_mining.csv
NGT_ORDERS_PATH=data/ngt_orders/

# ── Alerting (optional) ───────────────────────────────────────────────────────
# TWILIO_SID=your-sid
# TWILIO_TOKEN=your-token
# ALERT_PHONE=+91XXXXXXXXXX
